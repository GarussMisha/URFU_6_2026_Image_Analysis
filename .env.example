# ============================================
# ШАБЛОН КОНФИГУРАЦИИ ДЕТЕКТОРА ДВИЖЕНИЯ
# ============================================
# Скопируйте этот файл в .env и заполните значения
# ============================================

# Логин для доступа к камере
RTSP_USERNAME=

# Пароль для доступа к камере
RTSP_PASSWORD=

# IP-адрес камеры
RTSP_IP=

# Порт RTSP (обычно 554)
RTSP_PORT=554

# Поток: stream1 (основной, высокое качество) или stream2 (вторичный, больше FPS)
RTSP_STREAM=stream1
